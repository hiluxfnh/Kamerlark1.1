rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() { return request.auth != null; }
    // Images only, max 10 MB per file
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Profile pictures (login signup flow)
    match /profile_pictures/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId && isValidImage();
    }

    // Avatars (account management flow)
    match /users/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId && isValidImage();
    }

    // Room listing photos
    match /images/rooms/{ownerId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == ownerId && isValidImage();
    }

    // Chat images — uploader-scoped path; readable by signed-in users
    // (recipients access via download URL token or SDK)
    match /images/chat/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId && isValidImage();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
