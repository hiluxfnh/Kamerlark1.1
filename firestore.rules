rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isUser(uid) { return isSignedIn() && request.auth.uid == uid; }
    // Admin is granted exclusively via Firebase Auth custom claims
    // (set with the Admin SDK: admin.auth().setCustomUserClaims(uid, {admin: true})).
    // Never trust a user-writable document field for authorization.
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }

    // Users: public read, user can write own doc only.
    // Users must not be able to grant themselves privileges via doc fields.
    match /Users/{userId} {
      allow read: if true;
      allow create: if isUser(userId)
        && !('isAdmin' in request.resource.data);
      allow update: if isUser(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
      allow delete: if isUser(userId);
    }

    // Listings: public read; only owner can create/update/delete
    match /roomdetails/{roomId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Chat room mapping: visible/editable only to participants.
    // resource == null is the non-existent-doc case (getDoc on a new pair);
    // allowing that read lets ChatRoomHandler detect "not created yet" safely.
    match /chatRoomMapping/{mappingId} {
      allow read: if isSignedIn() && (resource == null || request.auth.uid in resource.data.userIds);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.userIds;
      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.userIds;
    }

    // Chat room: participants only; messages immutable once sent
    match /chatRoom/{roomId} {
      allow read: if isSignedIn() && (resource == null || request.auth.uid in resource.data.userIds);
      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.userIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.userIds;
      match /messages/{msgId} {
        allow read, create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chatRoom/$(roomId)).data.userIds;
        allow update, delete: if false;
      }
    }

    // Bookings contain PII (email/phone/address): only the booker, the
    // listing owner, or an admin may read; only the booker may create
    // (as themselves); booker or owner may update (e.g. status); booker may delete.
    match /bookings/{bookingId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            || resource.data.ownerId == request.auth.uid
            || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            || resource.data.ownerId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Appointments: same participant model as bookings
    match /appointments/{appointmentId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            || resource.data.ownerId == request.auth.uid
            || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            || resource.data.ownerId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Follows: social graph — readable by signed-in users; a user may only
    // create/delete follow edges where they are the follower.
    match /Follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followingId is string
        && request.resource.data.followerId != request.resource.data.followingId;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // Support tickets: the help form allows anonymous submissions, so create
    // is open but schema-validated and forced to status "open".
    // Only admins can read/manage tickets.
    match /supportTickets/{ticketId} {
      allow create: if request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() <= 200
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 5000
        && request.resource.data.status == 'open';
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
